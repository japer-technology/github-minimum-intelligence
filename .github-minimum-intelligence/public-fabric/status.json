                ]
              ]
            }
          ]
        },
        {
          "heading": "Infrastructure",
          "content": [
            {
              "type": "table",
              "headers": ["Dependency", "Role"],
              "rows": [
                ["GitHub Actions", "Sole compute runtime \u2014 every issue event triggers a workflow"],
                ["GitHub Issues", "Conversation interface \u2014 each issue maps to a persistent AI thread"],
                ["Git", "Memory &amp; storage layer \u2014 sessions, history, and edits committed"],
                ["<a href=\"https://bun.sh\" target=\"_blank\" rel=\"noopener\">Bun</a>", "JS/TS runtime for the agent orchestrator"],
                ["<a href=\"https://cli.github.com\" target=\"_blank\" rel=\"noopener\">gh CLI</a>", "GitHub API interaction \u2014 issues, comments, reactions"]
              ]
            }
          ]
        },
        {
          "heading": "LLM Providers",
          "headingSuffix": "(one required)",
          "content": [
            {
              "type": "table",
              "headers": ["Provider", "Models"],
              "rows": [
                ["<a href=\"https://platform.openai.com/\" target=\"_blank\" rel=\"noopener\">OpenAI</a>", "GPT models (default provider)"],
                ["<a href=\"https://console.anthropic.com/\" target=\"_blank\" rel=\"noopener\">Anthropic</a>", "Claude models"],
                ["<a href=\"https://aistudio.google.com/\" target=\"_blank\" rel=\"noopener\">Google Gemini</a>", "Gemini 2.5 Pro &amp; Flash"],
                ["<a href=\"https://console.x.ai/\" target=\"_blank\" rel=\"noopener\">xAI</a>", "Grok 3 &amp; Grok 3 Mini"],
                ["<a href=\"https://openrouter.ai/\" target=\"_blank\" rel=\"noopener\">OpenRouter</a>", "DeepSeek &amp; hundreds of models"],
                ["<a href=\"https://console.mistral.ai/\" target=\"_blank\" rel=\"noopener\">Mistral</a>", "Mistral Large &amp; others"],
                ["<a href=\"https://console.groq.com/\" target=\"_blank\" rel=\"noopener\">Groq</a>", "Fast inference \u2014 open-source models"]
              ]
            }
          ]
        }
      ]
    },
